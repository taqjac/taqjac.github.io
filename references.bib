  author = {Bousquet, Jean and Shamji, Mohamed H. and Anto, Josep M. and Sch{\"u}nemann, Holger J. and Canonica, G. Walter and Jutel, Marek and Del Giacco, Stefano and Zuberbier, Torsten and Pfaar, Oliver and Fonseca, Joao A. and {Sousa-Pinto}, Bernardo and Klimek, Ludger and Czarlewski, Wienczyslawa and Bedbrook, Anna and Amaral, Rita and Ansotegui, Ignacio J. and {Bosnic-Anticevich}, Sinthia and Braido, Fulvio and Loureiro, Claudia Chaves and Gemicioglu, Bilun and Haahtela, Tari and Kulus, Marek and Kuna, Piotr and Kupczyk, Maciej and Matricardi, Paolo M. and Regateiro, Frederico S. and Samolinski, Boleslaw and Sofiev, Mikhail and {Toppila-Salmi}, Sanna and Valiulis, Arunas and Ventura, Maria Teresa and Barbara, Cristina and Bergmann, Karl C. and Bewick, Michael and Blain, Hubert and Bonini, Matteo and Boulet, Louis-Philippe and Bourret, Rodolphe and Brusselle, Guy and Brussino, Luisa and Buhl, Roland and Cardona, Victoria and Casale, Thomas and Cecchi, Lorenzo and Charpin, Denis and {Cherrez-Ojeda}, Ivan and Chu, Derek K. and Cingi, Cemal and Costa, Elisio M. and Cruz, Alvaro A. and Devillier, Philippe and Dramburg, Stephanie and Fokkens, Wytske J. and Gotua, Maia and Heffler, Enrico and Ispayeva, Zhanat and Ivancevich, Juan Carlos and Joos, Guy and Kaidashev, Igor and Kraxner, Helga and Kvedariene, Violeta and {Larenas-Linnemann}, D{\'e}sir{\'e}e E. and Laune, Daniel and Louren{\c c}o, Olga and Louis, Renaud and Makela, Mika and Makris, Michael and Maurer, Marcus and Mel{\'e}n, Erik and Micheli, Yann and {Morais-Almeida}, Mario and Mullol, Joaquim and Niedoszytko, Marek and O'Hehir, Robyn and Okamoto, Yoshitaka and Olze, Heidi and Papadopoulos, Nikolaos G. and Papi, Alberto and Patella, Vincenzo and P{\'e}tr{\'e}, Benoit and {Pham-Thi}, Nh{\^a}n and Puggioni, Francesca and Quirce, Santiago and Roche, Nicolas and Rouadi, Philip W. and {S{\'a}-Sousa}, Ana and Sagara, Hironori and Sastre, Joaquin and Scichilone, Nicola and Sheikh, Aziz and Sova, Milan and Ulrik, Charlotte Suppli and {Taborda-Barata}, Luis and {Todo-Bom}, Ana and Torres, Maria J. and Tsiligianni, Ioanna and Usmani, Omar S. and Valovirta, Erkka and Vasankari, Tuula and Vieira, Rafael Jos{\'e} and Wallace, Dana and Waserman, Susan and Zidarn, Mihaela and Yorgancioglu, Arzu and Zhang, Luo and Chivato, Tomas and Ollert, Markus},
  journal = {Allergy},
  volume = {n/a},
  number = {n/a},
  issn = {1398-9995},
  doi = {10.1111/all.15740},
  urldate = {2023-04-20},
  abstract = {Biomarkers for the diagnosis, treatment and follow-up of patients with rhinitis and/or asthma are urgently needed. Although some biologic biomarkers exist in specialist care for asthma, they cannot be largely used in primary care. There are no validated biomarkers in rhinitis or allergen immunotherapy (AIT) that can be used in clinical practice. The digital transformation of health and health care (including mHealth) places the patient at the centre of the health system and is likely to optimise the practice of allergy. ARIA (Allergic Rhinitis and its Impact on Asthma) and EAACI (European Academy of Allergy and Clinical Immunology) developed a Task Force aimed at proposing patient-reported outcome measures (PROMs) as digital biomarkers that can be easily used for different purposes in rhinitis and asthma. It first defined control digital biomarkers that should make a bridge between clinical practice, randomised controlled trials, observational real-life studies and allergen challenges. Using the MASK-air app as a model, a daily electronic combined symptom-medication score for allergic diseases (CSMS) or for asthma (e-DASTHMA), combined with a monthly control questionnaire, were embedded in a strategy similar to the diabetes approach for disease control. To mimic real-life, it secondly proposed quality-of-life digital biomarkers including daily EQ-5D visual analogue scales and the bi-weekly RhinAsthma Patient Perspective (RAAP). The potential implications for the management of allergic respiratory diseases were proposed.},
  langid = {english},
  file = {/Users/tgjcnt/Zotero/storage/VEGVPCXA/Bousquet et al. - Patient-centred digital biomarkers for allergic re.pdf}
}

