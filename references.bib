  issn = {0098-7484},
  doi = {10.1001/jama.2023.14111},
  urldate = {2023-08-23},
  abstract = {The primary objectives of a confirmatory clinical trial, namely a clinical trial conducted with the intention of changing clinical practice or obtaining regulatory approval, are typically to demonstrate and quantify the benefit of a treatment in a specific population of patients. Occasionally, accumulating evidence makes it clear that an ongoing clinical trial is unlikely to meet its original goals. When this occurs, the trial may be stopped early for futility. Futility may result from lack of evidence supporting the desired benefit, from evidence of harm, or from practical issues that make successful completion unlikely.}
