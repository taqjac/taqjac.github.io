@article{culver2017,
  title = {Recommendations for a {{Standardized Pulmonary Function Report}}. {{An Official American Thoracic Society Technical Statement}}},
  author = {Culver, Bruce H. and Graham, Brian L. and Coates, Allan L. and Wanger, Jack and Berry, Cristine E. and Clarke, Patricia K. and Hallstrand, Teal S. and Hankinson, John L. and Kaminsky, David A. and MacIntyre, Neil R. and McCormack, Meredith C. and Rosenfeld, Margaret and Stanojevic, Sanja and Weiner, Daniel J.},
  year = {2017},
