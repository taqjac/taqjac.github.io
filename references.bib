  shorttitle = {Effects of a {{Web-Based Lifestyle Intervention}} on {{Weight Loss}} and {{Cardiometabolic Risk Factors}} in {{Adults With Overweight}} and {{Obesity}}},
  author = {Kohl, Jan and Brame, Judith and Centner, Christoph and Wurst, Ramona and Fuchs, Reinhard and Sehlbrede, Matthias and Tinsel, Iris and Maiwald, Phillip and Fichtner, Urs Alexander and Armbruster, Christoph and {Farin-Glattacker}, Erik and Gollhofer, Albert and K{\"o}nig, Daniel},
  year = {2023},
