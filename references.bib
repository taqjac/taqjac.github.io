@article{azevedo2013,
  title = {Control of {{Allergic Rhinitis}} and {{Asthma Test}} ({{CARAT}}): Dissemination and Applications in Primary Care.},
  author = {Azevedo, Pedro and {Correia de Sousa}, Jaime and Bousquet, Jean and {Bugalho-Almeida}, Ant{\'o}nio and Del Giacco, Stefano R. and Demoly, Pascal and Haahtela, Tari and Jacinto, Tiago and {Garcia-Larsen}, Vanessa and {van der Molen}, Thys and {Morais-Almeida}, M{\'a}rio and {Nogueira-Silva}, Luis and Pereira, Ana M. and Rodr{\'i}guez, Miguel Rom{\'a}n and Silva, B{\'a}rbara G. and Tsiligianni, Ioanna G. and Yaman, Hakan and Yawn, Barbara and Fonseca, Jo{\~a}o A.},
  year = {2013},
  month = mar,
  journal = {Prim Care Respir J},
  volume = {22},
  number = {1},
  pages = {112--116},
  address = {{England}},
  issn = {1475-1534 1471-4418},
  doi = {10.4104/pcrj.2013.00012},
  abstract = {Asthma frequently occurs in association with allergic rhinitis and a combined management approach has been suggested. The Control of Allergic Rhinitis and  Asthma Test (CARAT) is the first questionnaire to assess control of both diseases  concurrently. However, to have an impact on healthcare it needs to be  disseminated and adopted. In this paper we discuss the dissemination of CARAT in  different countries and its possible applications in primary care. At present,  the adaptation of CARAT for use in different languages and cultures is being led  by volunteer researchers and clinicians in 15 countries. Website and smartphone  applications have been developed, and a free open model of distribution was  adopted to contribute to the dissemination of CARAT. Examples of dissemination  activities include distribution of leaflets and posters, educational sessions on  the use of the questionnaire in the follow-up of patients, development of  clinical studies, collaborations with professional organisations and health  authorities, and the inclusion of CARAT in clinical guidelines. The adoption of  innovations is an important challenge in healthcare today, and research on the  degree of success of dissemination strategies using suitable methods and metrics  is much needed. We propose that CARAT can be used in a range of settings and  circumstances in primary care for clinical, research and audit purposes, within  the overall aim of increasing awareness of the level of disease control and  strengthening the partnership between patients and doctors in the management of  asthma and rhinitis.},
  langid = {english},
  pmcid = {PMC6442752},
  pmid = {23412110},
  keywords = {cv},
  file = {/Users/tgjcnt/Zotero/storage/HS9MUTPL/Azevedo et al. - 2013 - Control of Allergic Rhinitis and Asthma Test (CARA.pdf}
}

@article{azevedo2019,
  title = {{Avalia{\c c}{\~a}o Cr{\'i}tica de um Estudo de Revis{\~a}o Sistem{\'a}tica: Da Selec{\c c}{\~a}o {\`a} Avalia{\c c}{\~a}o da Qualidade dos Estudos Prim{\'a}rios}},
  shorttitle = {{Avalia{\c c}{\~a}o Cr{\'i}tica de um Estudo de Revis{\~a}o Sistem{\'a}tica}},
  author = {Azevedo, Lu{\'i}s Filipe and {Sousa-Pinto}, Bernardo},
  year = {2019},
  month = may,
  journal = {Revista da Sociedade Portuguesa de Anestesiologia},
  pages = {Vol 28 No 2 (2019): Revista da Sociedade Portuguesa de Anestesiologia},
  publisher = {{Revista da Sociedade Portuguesa de Anestesiologia}},
  doi = {10.25751/RSPA.17975},
  urldate = {2023-04-27},
  abstract = {Os processos iniciais para execu{\c c}{\~a}o de uma revis{\~a}o sistem{\'a}tica passam pela defini{\c c}{\~a}o da quest{\~a}o de investiga{\c c}{\~a}o e pesquisa de estudos prim{\'a}rios. Esta {\'u}ltima etapa tipicamente resulta na obten{\c c}{\~a}o de uma grande quantidade de estudos, a maioria dos quais n{\~a}o cumprem os crit{\'e}rios de elegibilidade. Assim, dever{\'a} ser levado a cabo um processo de selec{\c c}{\~a}o dos estudos prim{\'a}rios, de modo a identificar os estudos a incluir na revis{\~a}o sistem{\'a}tica. O processo de selec{\c c}{\~a}o dever{\'a} ser sempre efectuado por dois investigadores de modo independente, e compreende duas fases {\textendash} a fase de rastreio (com selec{\c c}{\~a}o dos registos por leitura do t{\'i}tulo e sum{\'a}rio) e a fase de inclus{\~a}o (implicando a leitura dos textos completos dos estudos). Uma vez seleccionados os estudos prim{\'a}rios a incluir na revis{\~a}o sistem{\'a}tica, dever-se-{\'a} proceder {\`a} extrac{\c c}{\~a}o dos dados e informa{\c c}{\~a}o relevantes e {\`a} avalia{\c c}{\~a}o da qualidade dos mesmos. A avalia{\c c}{\~a}o da qualidade dever{\'a} ter por base ferramentas pr{\'e}-definidas e revela-se um processo fundamental n{\~a}o s{\'o} para aferir a qualidade da evid{\^e}ncia existente relativamente a uma determinada quest{\~a}o de investiga{\c c}{\~a}o, mas tamb{\'e}m para identificar cuidados metodol{\'o}gicos a ter em futuros estudos ou para auxiliar {\`a} pr{\'o}pria s{\'i}ntese qualitativa e quantitativa de evid{\^e}ncia.},
  langid = {portuguese},
  file = {/Users/tgjcnt/Zotero/storage/ICB47LYK/Azevedo e Sousa-Pinto - 2019 - Avaliação Crítica de um Estudo de Revisão Sistemát.pdf}
}

