  author = {Cavallari Strozze Catharin, Virg{\'i}nia Maria and Zutin, Tereza La{\'i}s Menegucci and Guiguer, Elen Landgraf and Cressoni Ara{\'u}jo, Adriano and Fornari Laurindo, Lucas and Chagas, Eduardo F. Baisi and Gasparotti Zorzetto, C{\'a}ssia Fernanda and Bueno, Patr{\'i}cia C. Dos Santos and Dos Santos Bueno, Manoela and Cervelim Nunes, Yandra and Cavallari Strozze Catharin, Vitor and Gonzaga, Heron Fernando and Barbalho, Sandra Maria},
  year = {2023},
  month = aug,
  journal = {Diseases},
  volume = {11},
