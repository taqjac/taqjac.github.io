  title = {The {{Psychological Mechanisms Underlying Solomon}}'s {{Paradox}}: {{Impact}} of {{Mood}} and {{Self-Transcendence}}},
  shorttitle = {The {{Psychological Mechanisms Underlying Solomon}}'s {{Paradox}}},
  author = {Xu, Wentao and Zhang, Kaili and Wang, Fengyan},
