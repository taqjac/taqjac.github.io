@article{bradley2023,
  title = {Measuring Spirometry in a Lung Cancer Screening Cohort Highlights Possible Underdiagnosis and Misdiagnosis of {{COPD}}},
  author = {Bradley, Claire and Alexandris, Panos and Baldwin, David R. and Booton, Richard and Darby, Mike and Eckert, Claire J. and Gabe, Rhian and Hancock, Neil and Janes, Sam and Kennedy, Martyn and Lindop, Jason and Neal, Richard D. and Rogerson, Suzanne and Shinkins, Bethany and Simmonds, Irene and Upperton, Sara and Vestbo, Jorgen and Crosbie, Philip A. J. and Callister, Matthew E. J.},
  year = {2023},
