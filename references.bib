  author = {Hansen, James E and Sato, Makiko and Simons, Leon and Nazarenko, Larissa S and Sangha, Isabelle and Kharecha, Pushker and Zachos, James C and {von Schuckmann}, Karina and Loeb, Norman G and Osman, Matthew B and Jin, Qinjian and Tselioudis, George and Jeong, Eunbi and Lacis, Andrew and Ruedy, Reto and Russell, Gary and Cao, Junji and Li, Jing},
  year = {2023},
  month = jan,
  journal = {Oxford Open Climate Change},
  volume = {3},
  number = {1},
  pages = {kgad008},
  issn = {2634-4068},
  doi = {10.1093/oxfclm/kgad008},
  urldate = {2023-11-08},
  abstract = {Improved knowledge of glacial-to-interglacial global temperature change yields Charney (fast-feedback) equilibrium climate sensitivity 1.2 {$\pm$} 0.3{\textdegree}C (2{$\sigma$}) per W/m2, which is 4.8{\textdegree}C {$\pm$} 1.2{\textdegree}C for doubled CO2. Consistent analysis of temperature over the full Cenozoic era{\textemdash}including `slow' feedbacks by ice sheets and trace gases{\textemdash}supports this sensitivity and implies that CO2 was 300{\textendash}350 ppm in the Pliocene and about 450 ppm at transition to a nearly ice-free planet, exposing unrealistic lethargy of ice sheet models. Equilibrium global warming for today's GHG amount is 10{\textdegree}C, which is reduced to 8{\textdegree}C by today's human-made aerosols. Equilibrium warming is not `committed' warming; rapid phaseout of GHG emissions would prevent most equilibrium warming from occurring. However, decline of aerosol emissions since 2010 should increase the 1970{\textendash}2010 global warming rate of 0.18{\textdegree}C per decade to a post-2010 rate of at least 0.27{\textdegree}C per decade. Thus, under the present geopolitical approach to GHG emissions, global warming will exceed 1.5{\textdegree}C in the 2020s and 2{\textdegree}C before 2050. Impacts on people and nature will accelerate as global warming increases hydrologic (weather) extremes. The enormity of consequences demands a return to Holocene-level global temperature. Required actions include: (1) a global increasing price on GHG emissions accompanied by development of abundant, affordable, dispatchable clean energy, (2) East-West cooperation in a way that accommodates developing world needs, and (3) intervention with Earth's radiation imbalance to phase down today's massive human-made `geo-transformation' of Earth's climate. Current political crises present an opportunity for reset, especially if young people can grasp their situation.},
  file = {/Users/tgjcnt/Zotero/storage/RRFSX95V/Hansen et al. - 2023 - Global warming in the pipeline.pdf}
}

