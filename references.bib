@article{campo2023,
  title = {Does {{Poetry Make Nothing Happen}}?},
  author = {Campo, Rafael},
  year = {2023},
  month = may,
  journal = {JAMA},
  volume = {329},
  number = {20},
  pages = {1797},
  issn = {0098-7484},
  doi = {10.1001/jama.2023.8123},
  urldate = {2023-05-25},
  abstract = {The poem ``Fireflies'' opens with a counterfactual{\textemdash}the poem the author intended to write but did not is the poem that follows, which ends up reflecting the anguish following the May 2022 school shooting in Uvalde, Texas, where 19 children and 2 teachers were killed. A series of elegiac images depicting carefree youth tinged with a distant awareness of death's mysteries guides the reader to the poet's recognition that her ``{\ldots}childhood of glowworms, pigtails,/and tattered red sneakers flying through space/has vanished.'' The poem then powerfully concludes, as if it were powerless, ``Silence became gunshots, laughter/fear, golden dots the blood/of children scattered on a schoolroom floor./I'd wanted to write about fireflies.'' We are reminded here of W. H. Auden's famous ironic line, from his elegy for another great poet of his time, W. B. Yeats, ``Poetry makes nothing happen.'' Both Yeats and Auden wrote during times of violent political conflict and seismic global strife; their poems locate a role for art in the midst of such upheaval. Poetry ``survives,'' Auden goes on to write, and is ``a way of happening, a mouth.'' ``Fireflies'' similarly implicates us in survival and witness. The ``nothing'' (like ephemeral fireflies) that poetry makes happen is indeed something: an indelible expression of shared grief, an acknowledgement of common humanity in the face of immutable mortality, a blinking of light in the darkness. Ultimately, the senselessness made tangible here is of value if physicians and the lay public can put despair and political rhetoric aside to reduce firearm deaths and advance the public's health.},
  file = {/Users/tgjcnt/Zotero/storage/APEDUU4U/Campo - 2023 - Does Poetry Make Nothing Happen.pdf}
}

