  journal = {The Journal of Allergy and Clinical Immunology: In Practice},
  issn = {2213-2198},
  doi = {10.1016/j.jaip.2023.08.027},
  urldate = {2023-08-29},
  abstract = {Background Exhaled nitric oxide (FENO) is used as a marker of type-2 (T2) airway inflammation in asthma management. Studies with airway challenges demonstrated that a reduction of airway calibre decreases FENO levels. Objective To evaluate the impact of airway calibre reduction occurring spontaneously in asthma patients on FENO values in daily clinical practice. Methods In this post-hoc analysis, FENO, FEV1 and asthma control questionnaire (ACQ) scores were recorded on each visit for 120 (1073 visits) adult asthma patients. Blood eosinophils (B-Eos) were measured intermittently. Intra-individual relationship between FENO and FEV1 was evaluated via a linear mixed model. The determinants of the individual mean FENO were measured by a stepwise multivariate linear model including individual mean FEV1, ICS dose, ACQ score and B-Eos. Results Variations in the negative FENO-FEV1 relationship within individuals at different times were significantly determined by the individual's mean FEV1. This relationship did not hold for individuals above the 75th and below the 25th quartiles. The best explanatory variables for individual mean FENO were FEV1 (+4.3 ppb.10\%pred-1) and B-Eos (+1 ppb per 100 cells/mm3). Discussion In the presence of variable degrees of heterogenous patterns of airway inflammation, airway calibre is shown to be an independent and significant determinant of FENO when measured in asthma patients. We would propose a +4ppb correction factor to the measured FENO value for each 10\% reduction below 100\% predicted FEV1. Doing this should improve the rigor of interpretation of FENO as an indicator of T2 inflammation in patients with low FEV1.}
}

@article{milic-emili1997,
