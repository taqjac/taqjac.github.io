@article{knight2003,
  title = {The Airway Epithelium: {{Structural}} and Functional Properties in Health and Disease},
  shorttitle = {The Airway Epithelium},
  author = {Knight, Darryl A. and Holgate, Stephen T.},
  year = {2003},
  journal = {Respirology},
  volume = {8},
