  abstract = {The influence of technology on undergraduate medical education has had a long and bumpy road. Ludmerer concluded one of his authoritative works on the history of medical education in the US by warning, nearly 40 years ago, about the deleterious effects of uncontrolled technology on the development of students. At the same time, some of the brightest opportunities for transformation in teaching and learning have been catalyzed by shifts in technology. In 2023, with the advent of generative artificial intelligence (AI) tools over the past year, society is facing one of those moments now.Decades ago, some of the most respected teaching physicians were those who knew the most about their subject. Access to information was hard to come by and knowledge through study and experience was hard-won. The advent of powerful internet search engines led to a shift in attitude. Knowledge alone was no longer as impressive. Everyone became better not just at remembering things, but at differentiating good information from bad, synthesizing and comparing different data sets, and applying a critical eye to large amounts of signal and noise. In the preclinical curricula at many medical schools, there was a shift away from lectures (an efficient method of transferring facts) to discussion-based formats (which allow for more practice in knowledge integration, analysis, and communication). In fact, the adept clinician had always been a subject expert, a critical thinker, and a presenter extraordinaire, and this now came into fuller view for students.}
}

@article{charness,
  title = {Generation {{Next}}: {{Experimentation}} with {{AI}}},
  author = {Charness, Gary and Jabarian, Brian and List, John A},
  abstract = {We investigate the potential for Large Language Models (LLMs) to enhance scientific practice within experimentation by identifying key areas, directions, and implications. First, we discuss how these models can improve experimental design, including improving the elicitation wording, coding experiments, and producing documentation. Second, we discuss the implementation of experiments using LLMs, focusing on enhancing causal inference by creating consistent experiences, improving comprehension of instructions, and monitoring participant engagement in real time. Third, we highlight how LLMs can help analyze experimental data, including preprocessing, data cleaning, and other analytical tasks while helping reviewers and replicators investigate studies. Each of these tasks improves the probability of reporting accurate findings.},
  langid = {english},
  file = {/Users/tgjcnt/Zotero/storage/KAYHLQQX/Charness et al. - Generation Next Experimentation with AI.pdf}
}

