@article{2023a,
  title = {The {{Hygiene}} of {{Music}}},
  year = {2023},
  month = jul,
  journal = {JAMA},
  volume = {330},
  number = {4},
  pages = {383},
  issn = {0098-7484},
  doi = {10.1001/jama.2022.15990},
  urldate = {2023-07-26},
  abstract = {A witty popular writer makes the suggestion that with the growth of utilitarian ideals, music will gradually come to be looked upon, not as a dignified and civilizing art, but as a sort of minor vice; an amiable but enervating dissipation. While there is probably little chance that our ideals will become so completely utilitarian as he suggests, there is nevertheless something in the idea he advances that is perhaps worthy of consideration. It is certainly a curious fact that one form of sensual indulgence, or perhaps one might say more acceptably, sensuous enjoyment{\ldots}should be lauded as in every way meritorious, even when excessive, while others of far greater real utility are considered, if at all overdone, as hardly respectable, if not absolutely disreputable. This is not because of its intellectual element, for it has as little of that as any form of sensory gratification{\ldots} It appeals solely to the emotional and physical sides of our nature and it is a not unreasonable query whether, in so acting, its effects are always and in every way beneficial or desirable.}
}

