  author = {Malerbi, Fernando Korn and Nakayama, Luis Filipe and Gayle Dychiao, Robyn and Zago Ribeiro, Lucas and Villanueva, Cleva and Celi, Leo Anthony and Regatieri, Caio Vinicius},
  year = {2023},
