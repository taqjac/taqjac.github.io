  author = {{Vieira-Marques}, Pedro and Almeida, Rute and Teixeira, Jo{\~a}o F. and Valente, Jos{\'e} and J{\'a}come, Cristina and Cachim, Afonso and Guedes, Rui and Pereira, Ana and Jacinto, Tiago and Fonseca, Jo{\~a}o A.},
