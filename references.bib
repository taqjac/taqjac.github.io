  author = {Hall, Graham L. and Filipow, Nicole and Ruppel, Gregg and Okitika, Tolu and Thompson, Bruce and Kirkby, Jane and Steenbruggen, Irene and Cooper, Brendan G. and Stanojevic, Sanja and Members, on behalf of the contributing GLI Network},
  year = {2021},
