  issn = {0098-7484},
  doi = {10.1001/jama.2023.14525},
  urldate = {2023-09-06},
  abstract = {More than a few commentators have seriously inquired whether artificial intelligence (AI) could ultimately replace many clinicians. The far likelier prospect, however, is that the newly emerging technology will enhance clinical productivity.To be sure, AI-based pattern recognition software can already scan retinal photos for complications of diabetes, detect tuberculosis on chest x-rays, and evaluate screening mammograms. And some AI applications have been found to be comparable if not superior to human clinical judgment. But in the end, urologists will continue to perform cystoscopy, aided by AI-based improvements in the procedure's diagnostic accuracy. Cardiologists will still perform cardiac catheterization, similarly aided by AI-based gains in clinical assessment. And neurologists will continue to treat Parkinson disease, aided by AI-based advances in early detection.}
}

@article{hassan2023,
