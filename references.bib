  month = aug,
  journal = {Journal of Hazardous Materials},
  volume = {416},
  pages = {126124},
  issn = {0304-3894},
  doi = {10.1016/j.jhazmat.2021.126124},
  urldate = {2023-06-09},
  abstract = {Plastics are ubiquitously used by societies, but most of the plastic waste is deposited in landfills and in the natural environment. Their degradation into submillimetre fragments, called microplastics, is a growing concern due to potential adverse effects on the environment and human health. Microplastics are present in the air and may be inhaled by humans, but whether they have deleterious effects on the respiratory system remain unknown. In this study, we determined the presence of microplastics in human lung tissues obtained at autopsies. Polymeric particles (n~=~33) and fibres (n~=~4) were observed in 13 of 20 tissue samples. All polymeric particles were smaller than 5.5~{\textmu}m in size, and fibres ranged from 8.12 to 16.8~{\textmu}m. The most frequently determined polymers were polyethylene and polypropylene. Deleterious health outcomes may be related to the heterogeneous characteristics of these contaminants in the respiratory system following inhalation.},
  langid = {english},
  file = {/Users/tgjcnt/Zotero/storage/RS6DU2Z8/Amato-Lourenço et al. - 2021 - Presence of airborne microplastics in human lung t.pdf}
}

