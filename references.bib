@article{kapus2022,
  title = {Relationship between Body Composition and Pulmonary Function in Healthy Adolescents},
  author = {Kapu{\v s}, Ond{\v r}ej and Fellnerov{\'a}, Ivana and Chaloupkov{\'a}, Pavla and Marti{\v s}ov{\'a}, Karol{\'i}na},
