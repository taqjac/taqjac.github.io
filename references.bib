@article{dykstra1999,
  title = {Lung Volumes in 4,774 Patients with Obstructive Lung Disease},
  author = {Dykstra, B. J. and Scanlon, P. D. and Kester, M. M. and Beck, K. C. and Enright, P. L.},
  year = {1999},
